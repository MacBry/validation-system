# ============================================================================
# VCC ENVIRONMENT VARIABLES TEMPLATE
# ============================================================================
# Copy this file to .env and fill in ALL values before starting the application.
# NEVER commit the .env file to version control.
# ============================================================================

# ---- DATABASE ----
DB_USERNAME=validationuser
DB_PASSWORD=
MYSQL_ROOT_PASSWORD=

# ---- REDIS ----
REDIS_PASSWORD=

# ---- SECURITY ----
# Remember-me key must be 32+ characters, cryptographically random
REMEMBER_ME_KEY=
# SSL keystore password (for HTTPS and PDF signing)
SSL_KEYSTORE_PASSWORD=
SIGNING_KEYSTORE_PASSWORD=
# Default admin password (for initial setup only - change immediately after first login)
DEFAULT_ADMIN_PASSWORD=

# ---- MAIL ----
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_SMTP_AUTH=true
MAIL_STARTTLS=true

# ---- TSA (Time Stamp Authority) ----
TSA_URL=http://timestamp.digicert.com
TSA_USERNAME=
TSA_PASSWORD=

# ---- VPS DEPLOYMENT (for deploy scripts only) ----
VPS_HOST=
VPS_PORT=22
VPS_USER=
VPS_PASS=

# ---- SSL / SESSION ----
SSL_ENABLED=false
SESSION_COOKIE_SECURE=true

# ---- BACKUP (optional) ----
BACKUP_S3_BUCKET=
BACKUP_S3_REGION=eu-central-1
BACKUP_GPG_RECIPIENT=
BACKUP_ALERT_EMAIL=
BACKUP_SLACK_WEBHOOK=
