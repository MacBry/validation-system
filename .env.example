# ============================================================================
# VCC PRODUCTION ENVIRONMENT VARIABLES TEMPLATE
# ============================================================================
# Copy this file to .env and fill in the values

# DATABASE
DB_ROOT_PASSWORD=change_this_root_password
DB_USERNAME=vcc_user
DB_PASSWORD=change_this_user_password

# REDIS
REDIS_PASSWORD=change_this_redis_password

# SECURITY
REMEMBER_ME_KEY=change_this_long_random_string
SSL_KEYSTORE_PASSWORD=change_this_keystore_password

# MAIL
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# TSA (Time Stamp Authority)
TSA_URL=http://***REMOVED***:8080/tsa
TSA_USERNAME=admin
TSA_PASSWORD=admin
