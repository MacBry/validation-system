# =============================================================================
# MySQL client credentials for backup sidecar
# =============================================================================
# SECURITY: This file must be mounted read-only (chmod 400) and contain
#           only the backup user credentials (not root).
#
# In production, replace this with Docker secrets or Vault integration.
# This template uses environment variable substitution at container start.
# =============================================================================

[client]
# These are populated via environment variables in Docker
# For non-Docker use: replace with actual credentials
user=validation_user
# password is read from DB_PASSWORD environment variable

[mysqldump]
user=validation_user
# password is read from DB_PASSWORD environment variable
quick
single-transaction
max_allowed_packet=512M
routines
triggers
events
hex-blob
