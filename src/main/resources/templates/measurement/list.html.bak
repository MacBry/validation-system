<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org" lang="pl">
<head>
<meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Serie pomiarowe</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
:root{--g1:#667eea;--g2:#764ba2;--white:#fff;--surface:#f7f8fc;--border:#e8eaf0;--tm:#1a1d2e;--ts:#6b7080;--sh:0 20px 60px rgba(0,0,0,.18);--shm:0 8px 32px rgba(102,126,234,.15);--r:14px;--rs:8px}
body{font-family:'DM Sans',sans-serif;background:linear-gradient(135deg,var(--g1),var(--g2));min-height:100vh;padding:24px 24px 40px;color:var(--tm)}
.page{max-width:1200px;margin:0 auto}
.topnav{display:flex;align-items:center;justify-content:space-between;margin-bottom:28px;flex-wrap:wrap;gap:12px}
.brand{color:#fff;font-size:1.2rem;font-weight:600;letter-spacing:-.01em}
.brand span{opacity:.6;font-weight:400}
.nav-links{display:flex;gap:8px;flex-wrap:wrap}
.nav-link{color:rgba(255,255,255,.75);text-decoration:none;font-size:.85rem;font-weight:500;padding:6px 14px;border-radius:20px;border:1px solid rgba(255,255,255,.25);transition:all .2s}
.nav-link:hover,.nav-link.active{background:rgba(255,255,255,.15);color:#fff}
.toolbar{display:flex;align-items:center;justify-content:space-between;margin-bottom:20px;flex-wrap:wrap;gap:12px}
.toolbar-title{color:#fff;font-size:1.5rem;font-weight:600}
.btn-add{display:inline-flex;align-items:center;gap:8px;background:#fff;color:var(--g1);border:none;border-radius:var(--rs);padding:10px 20px;font-size:.9rem;font-weight:600;font-family:'DM Sans',sans-serif;cursor:pointer;text-decoration:none;transition:opacity .2s,transform .15s}
.btn-add:hover{opacity:.9;transform:translateY(-1px)}
.btn-add svg{width:18px;height:18px}
.card{background:var(--white);border-radius:var(--r);box-shadow:var(--sh);overflow-x:auto}
.flash{padding:14px 20px;font-size:.88rem;font-weight:500;border-radius:var(--rs);margin-bottom:16px}
.flash.ok{background:#f0fdf4;border:1px solid #86efac;color:#166534}
.flash.warn{background:#fef3c7;border:1px solid #fbbf24;color:#92400e}
.flash.err{background:#fef2f2;border:1px solid #fca5a5;color:#991b1b}
.empty-state{padding:60px 20px;text-align:center;color:var(--ts)}
.empty-state svg{width:48px;height:48px;margin-bottom:16px;opacity:.4}
.empty-state p{font-size:1rem;margin-bottom:4px}
.empty-state small{font-size:.82rem}
table{width:100%;border-collapse:collapse;border-radius:var(--r)}
thead tr{border-bottom:2px solid var(--border)}
thead th{padding:14px 18px;font-size:.72rem;font-weight:600;text-transform:uppercase;letter-spacing:.06em;color:var(--ts);text-align:left;white-space:nowrap}
thead th:first-child{border-radius:var(--r) 0 0 0}
thead th:last-child{border-radius:0 var(--r) 0 0}
tbody tr{border-bottom:1px solid var(--border);transition:background .15s}
tbody tr:last-child{border-bottom:none}
tbody tr:hover{background:var(--surface)}
td{padding:14px 18px;font-size:.88rem;color:var(--tm);vertical-align:middle}
.file-name{font-family:'DM Mono',monospace;font-size:.82rem;color:var(--g1);text-decoration:none;font-weight:500}
.file-name:hover{color:var(--g2)}
.serial{font-size:.8rem;color:var(--ts);font-family:'DM Mono',monospace}
.time-block{font-size:.78rem;color:var(--ts);line-height:1.7}
.time-block b{color:var(--tm);font-size:.8rem}
.temp-range{font-weight:600;color:var(--tm)}
.upload-date{font-size:.78rem;color:var(--ts)}
.actions{display:flex;gap:6px;justify-content:flex-end;white-space:nowrap}
.btn-detail{display:inline-flex;align-items:center;gap:5px;padding:6px 12px;background:linear-gradient(135deg,var(--g1),var(--g2));color:#fff;text-decoration:none;border-radius:var(--rs);font-size:.78rem;font-weight:600;transition:opacity .2s;white-space:nowrap}
.btn-detail:hover{opacity:.85}
.filter-toggle{display:flex;gap:8px;background:rgba(255,255,255,.1);border-radius:var(--rs);padding:4px}
.filter-btn{display:inline-flex;align-items:center;gap:6px;padding:6px 12px;background:transparent;color:rgba(255,255,255,.7);text-decoration:none;border-radius:6px;font-size:.82rem;font-weight:500;transition:all .2s;white-space:nowrap}
.filter-btn.active{background:#fff;color:var(--g1);box-shadow:0 2px 8px rgba(0,0,0,.1)}
.filter-btn:hover:not(.active){background:rgba(255,255,255,.15);color:#fff}
.filter-btn svg{width:14px;height:14px}
.btn-del{display:inline-flex;align-items:center;gap:5px;padding:6px 12px;background:transparent;color:#e53e3e;border:1.5px solid #e53e3e;border-radius:var(--rs);font-size:.78rem;font-weight:600;cursor:pointer;font-family:'DM Sans',sans-serif;transition:all .2s;white-space:nowrap}
.btn-del:hover{background:#e53e3e;color:#fff}
.footer-bar{display:flex;align-items:center;padding:16px 20px;border-top:1px solid var(--border);color:var(--ts);font-size:.82rem;gap:8px}
.footer-bar .count{background:linear-gradient(135deg,var(--g1),var(--g2));color:#fff;border-radius:20px;padding:2px 12px;font-weight:600}
</style>
</head>
<body>
<div class="page">
  <nav class="topnav">
    <span class="brand">Validation System <span>/ Pomiary</span></span>
    <div class="nav-links">
      <a href="/measurements" class="nav-link active">Pomiary</a>
      <a href="/devices" class="nav-link">Urządzenia</a>
      <a href="/recorders" class="nav-link">Rejestratory</a>
      <a href="/departments" class="nav-link">Działy</a>
      <a href="/laboratories" class="nav-link">Pracownie</a>
      <a href="/validations" class="nav-link">Walidacje</a>
      <a href="/material-types" class="nav-link">Materiały</a>
    </div>
  </nav>

  <div class="toolbar">
    <span class="toolbar-title">Serie pomiarowe TESTO</span>
    <div style="display:flex;gap:12px;align-items:center">
      <!-- Przełącznik filtra -->
      <div class="filter-toggle">
        <a th:href="@{/measurements(showUsed=false)}" 
           th:class="${filterType == 'unused' ? 'filter-btn active' : 'filter-btn'}">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
            <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14zm0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16z"/>
            <path d="M10.97 4.97a.235.235 0 0 0-.02.022L7.477 9.417 5.384 7.323a.75.75 0 0 0-1.06 1.06L6.97 11.03a.75.75 0 0 0 1.079-.02l3.992-4.99a.75.75 0 0 0-1.071-1.05z"/>
          </svg>
          Wolne
        </a>
        <a th:href="@{/measurements(showUsed=true)}" 
           th:class="${filterType == 'used' ? 'filter-btn active' : 'filter-btn'}">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
            <path d="M11 6.5a.5.5 0 0 1 .5-.5h1a.5.5 0 0 1 .5.5v1a.5.5 0 0 1-.5.5h-1a.5.5 0 0 1-.5-.5v-1z"/>
            <path d="M4.5 8a3.5 3.5 0 1 0 0 7h7a3.5 3.5 0 1 0 0-7h-7z"/>
          </svg>
          Użyte
        </a>
      </div>
      <a th:href="@{/measurements/upload}" class="btn-add">
        <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"/></svg>
        Prześlij pliki .vi2
      </a>
    </div>
  </div>

  <div th:if="${success}" class="flash ok" th:text="${success}"></div>
  <div th:if="${error}" class="flash err" th:text="${error}"></div>
  
  <!-- Warnings -->
  <div th:if="${warnings != null && !#lists.isEmpty(warnings)}" class="flash warn">
    <strong>⚠️ Ostrzeżenia:</strong>
    <ul style="margin:8px 0 0 0;padding-left:20px">
      <li th:each="warning : ${warnings}" th:text="${warning}" style="margin:4px 0"></li>
    </ul>
  </div>
  
  <!-- Errors (lista) -->
  <div th:if="${errors != null && !#lists.isEmpty(errors)}" class="flash err">
    <strong>❌ Błędy:</strong>
    <ul style="margin:8px 0 0 0;padding-left:20px">
      <li th:each="err : ${errors}" th:text="${err}" style="margin:4px 0"></li>
    </ul>
  </div>

  <form id="validationForm" action="/validations/create" method="post">
    <div style="margin-bottom:16px;padding:12px;background:rgba(255,255,255,.08);border:1.5px solid rgba(255,255,255,.2);border-radius:var(--radius)">
      <button type="submit" style="padding:10px 20px;background:linear-gradient(135deg,#10b981,#059669);color:#fff;border:none;border-radius:var(--radius);font-size:.9rem;font-weight:600;cursor:pointer;font-family:'DM Sans',sans-serif;box-shadow:0 4px 12px rgba(16,185,129,.3);transition:all .2s">
        <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" style="width:18px;height:18px;display:inline-block;vertical-align:middle;margin-right:6px"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        Wykonaj walidację z zaznaczonych
      </button>
      <span style="margin-left:12px;font-size:.82rem;color:var(--ts)">Zaznacz serie, które mają być użyte w walidacji</span>
    </div>

    <div class="card">
    <div th:if="${#lists.isEmpty(measurementSeries)}" class="empty-state">
      <svg fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 17v-2m3 2v-4m3 4v-6M4 19h16a1 1 0 001-1V7l-5-5H5a1 1 0 00-1 1v15a1 1 0 001 1z"/></svg>
      <p>Brak serii pomiarowych</p>
      <small>Kliknij "Prześlij pliki .vi2" aby dodać pierwsze pomiary</small>
    </div>
    <table th:unless="${#lists.isEmpty(measurementSeries)}">
      <thead>
        <tr>
          <th style="width:40px">
            <input type="checkbox" id="selectAll" style="width:18px;height:18px;cursor:pointer">
          </th>
          <th>Plik / Rejestrator</th>
          <th style="width:180px">Pozycja</th>
          <th>Okres pomiarów</th>
          <th>Zakres temp.</th>
          <th>Przesłano</th>
          <th style="width:1%;white-space:nowrap">Akcje</th>
        </tr>
      </thead>
      <tbody>
        <tr th:each="series : ${measurementSeries}">
          <td style="text-align:center">
            <input type="checkbox" name="seriesIds" th:value="${series.id}" class="series-checkbox" style="width:18px;height:18px;cursor:pointer">
          </td>
          <td>
            <a th:href="@{/measurements/{id}(id=${series.id})}" th:text="${series.originalFilename}" class="file-name">plik.vi2</a>
            <div th:if="${series.recorderSerialNumber != null}" class="serial" th:text="'#' + ${series.recorderSerialNumber}"></div>
          </td>
          <td>
            <span th:if="${series.recorderPosition != null}"
                  style="display:inline-block;font-size:.75rem;font-weight:500;color:var(--ts);background:var(--surface);border:1px solid var(--border);border-radius:var(--rs);padding:3px 9px;white-space:nowrap"
                  th:text="${series.recorderPosition.displayName}">–</span>
            <span th:unless="${series.recorderPosition != null}" style="color:#e53e3e;font-size:.78rem">Brak</span>
          </td>
          <td>
            <div class="time-block">
              <div><b>Od:</b> <span th:text="${series.formattedFirstMeasurementTime}">–</span></div>
              <div><b>Do:</b> <span th:text="${series.formattedLastMeasurementTime}">–</span></div>
              <div th:text="'(' + ${series.duration} + ')'"></div>
            </div>
          </td>
          <td><span class="temp-range" th:text="${series.temperatureRange}">–</span></td>
          <td><span class="upload-date" th:text="${series.formattedUploadDate}">–</span></td>
          <td>
            <div class="actions">
              <a th:href="@{/measurements/{id}(id=${series.id})}" class="btn-detail">Szczegóły</a>
              <form th:action="@{/measurements/{id}/delete(id=${series.id})}" method="post" style="display:inline" onsubmit="return confirm('Usunąć tę serię pomiarową?')">
                <button type="submit" class="btn-del">Usuń</button>
              </form>
            </div>
          </td>
        </tr>
      </tbody>
    </table>
    <div th:unless="${#lists.isEmpty(measurementSeries)}" class="footer-bar">
      Łącznie: <span class="count" th:text="${#lists.size(measurementSeries)}">0</span> serii pomiarowych
    </div>
  </div>
</form>

<script>
// Zaznacz/odznacz wszystkie checkboxy
document.getElementById('selectAll')?.addEventListener('change', function(e) {
  const checkboxes = document.querySelectorAll('.series-checkbox');
  checkboxes.forEach(cb => cb.checked = e.target.checked);
});

// Aktualizuj "zaznacz wszystkie" gdy pojedyncze checkboxy się zmieniają
document.querySelectorAll('.series-checkbox').forEach(cb => {
  cb.addEventListener('change', function() {
    const all = document.querySelectorAll('.series-checkbox');
    const checked = document.querySelectorAll('.series-checkbox:checked');
    document.getElementById('selectAll').checked = (all.length === checked.length && all.length > 0);
  });
});
</script>

</div>
</body>
</html>
