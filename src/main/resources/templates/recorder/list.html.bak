<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org" lang="pl">
<head>
<meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Rejestratory TESTO</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
:root{--g1:#667eea;--g2:#764ba2;--white:#fff;--surface:#f7f8fc;--border:#e8eaf0;--tm:#1a1d2e;--ts:#6b7080;--sh:0 20px 60px rgba(0,0,0,.18);--r:14px;--rs:8px}
body{font-family:'DM Sans',sans-serif;background:linear-gradient(135deg,var(--g1),var(--g2));min-height:100vh;padding:24px 16px 40px;color:var(--tm)}
.page{max-width:1000px;margin:0 auto}
.topnav{display:flex;align-items:center;justify-content:space-between;margin-bottom:28px;flex-wrap:wrap;gap:12px}
.brand{color:#fff;font-size:1.2rem;font-weight:600}
.brand span{opacity:.6;font-weight:400}
.nav-links{display:flex;gap:8px;flex-wrap:wrap}
.nav-link{color:rgba(255,255,255,.75);text-decoration:none;font-size:.85rem;font-weight:500;padding:6px 14px;border-radius:20px;border:1px solid rgba(255,255,255,.25);transition:all .2s}
.nav-link:hover,.nav-link.active{background:rgba(255,255,255,.15);color:#fff}
.toolbar{display:flex;align-items:center;justify-content:space-between;margin-bottom:20px;gap:12px;flex-wrap:wrap}
.toolbar-title{color:#fff;font-size:1.5rem;font-weight:600}
.toolbar-right{display:flex;gap:8px}
.btn-add{display:inline-flex;align-items:center;gap:8px;background:#fff;color:var(--g1);border:none;border-radius:var(--rs);padding:10px 20px;font-size:.9rem;font-weight:600;text-decoration:none;transition:opacity .2s,transform .15s}
.btn-add:hover{opacity:.9;transform:translateY(-1px)}
.btn-refresh{display:inline-flex;align-items:center;gap:8px;background:rgba(255,255,255,.15);color:#fff;border:1px solid rgba(255,255,255,.3);border-radius:var(--rs);padding:10px 18px;font-size:.88rem;font-weight:500;cursor:pointer;font-family:'DM Sans',sans-serif;transition:background .2s}
.btn-refresh:hover{background:rgba(255,255,255,.25)}
.btn-refresh svg,.btn-add svg{width:16px;height:16px}
.card{background:var(--white);border-radius:var(--r);box-shadow:var(--sh);overflow:hidden}
.empty-state{padding:60px 20px;text-align:center;color:var(--ts)}
.empty-state svg{width:48px;height:48px;margin-bottom:16px;opacity:.4}
table{width:100%;border-collapse:collapse}
thead tr{border-bottom:2px solid var(--border)}
thead th{padding:14px 18px;font-size:.72rem;font-weight:600;text-transform:uppercase;letter-spacing:.06em;color:var(--ts);text-align:left}
tbody tr{border-bottom:1px solid var(--border);transition:background .15s}
tbody tr:last-child{border-bottom:none}
tbody tr:hover{background:var(--surface)}
td{padding:14px 18px;font-size:.88rem;color:var(--tm);vertical-align:middle}
.serial{font-family:'DM Mono',monospace;font-weight:600}
.model{font-weight:500}
.badge-active{display:inline-block;background:#dcfce7;color:#166534;border:1px solid #86efac;border-radius:20px;padding:3px 12px;font-size:.75rem;font-weight:600}
.badge-inactive{display:inline-block;background:#fef2f2;color:#991b1b;border:1px solid #fca5a5;border-radius:20px;padding:3px 12px;font-size:.75rem;font-weight:600}
.actions{display:flex;gap:6px;justify-content:flex-end}
.btn-detail{display:inline-flex;align-items:center;padding:6px 12px;background:linear-gradient(135deg,var(--g1),var(--g2));color:#fff;text-decoration:none;border-radius:var(--rs);font-size:.78rem;font-weight:600;transition:opacity .2s}
.btn-detail:hover{opacity:.85}
.btn-edit{display:inline-flex;align-items:center;padding:6px 12px;background:transparent;color:var(--g1);border:1.5px solid var(--g1);text-decoration:none;border-radius:var(--rs);font-size:.78rem;font-weight:600;transition:all .2s}
.btn-edit:hover{background:var(--g1);color:#fff}
.btn-del{display:inline-flex;align-items:center;padding:6px 12px;background:transparent;color:#e53e3e;border:1.5px solid #e53e3e;border-radius:var(--rs);font-size:.78rem;font-weight:600;cursor:pointer;font-family:'DM Sans',sans-serif;transition:all .2s}
.btn-del:hover{background:#e53e3e;color:#fff}
.footer-bar{display:flex;align-items:center;padding:16px 20px;border-top:1px solid var(--border);color:var(--ts);font-size:.82rem;gap:8px}
.footer-bar .count{background:linear-gradient(135deg,var(--g1),var(--g2));color:#fff;border-radius:20px;padding:2px 12px;font-weight:600}
</style>
</head>
<body>
<div class="page">
  <nav class="topnav">
    <span class="brand">Validation System <span>/ Rejestratory</span></span>
    <div class="nav-links">
      <a href="/measurements" class="nav-link">Pomiary</a>
      <a href="/devices" class="nav-link">Urządzenia</a>
      <a href="/recorders" class="nav-link active">Rejestratory</a>
      <a href="/departments" class="nav-link">Działy</a>
      <a href="/laboratories" class="nav-link">Pracownie</a>
      <a href="/validations" class="nav-link">Walidacje</a>
      <a href="/material-types" class="nav-link">Materiały</a>
    </div>
  </nav>
  <div class="toolbar">
    <span class="toolbar-title">Rejestratory TESTO</span>
    <div class="toolbar-right">
      <form th:action="@{/recorders/update-statuses}" method="post">
        <button type="submit" class="btn-refresh">
          <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
          Aktualizuj statusy
        </button>
      </form>
      <a th:href="@{/recorders/new}" class="btn-add">
        <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/></svg>
        Dodaj rejestrator
      </a>
    </div>
  </div>
  <div class="card">
    <div th:if="${#lists.isEmpty(recorders)}" class="empty-state">
      <svg fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 3H5a2 2 0 00-2 2v4m6-6h10a2 2 0 012 2v4M9 3v18m0 0h10a2 2 0 002-2V9M9 21H5a2 2 0 01-2-2V9m0 0h18"/></svg>
      <p>Brak rejestratorów w systemie</p>
    </div>
    <table th:unless="${#lists.isEmpty(recorders)}">
      <thead>
        <tr><th>Numer seryjny</th><th>Model</th><th>Status</th><th style="text-align:right">Akcje</th></tr>
      </thead>
      <tbody>
        <tr th:each="recorder : ${recorders}">
          <td><span class="serial" th:text="${recorder.serialNumber}">–</span></td>
          <td><span class="model" th:text="${recorder.model}">–</span></td>
          <td>
            <span th:if="${recorder.status.name() == 'ACTIVE'}" class="badge-active" th:text="${recorder.status.displayName}">Aktywny</span>
            <span th:if="${recorder.status.name() == 'INACTIVE'}" class="badge-inactive" th:text="${recorder.status.displayName}">Nieaktywny</span>
          </td>
          <td>
            <div class="actions">
              <a th:href="@{/recorders/{id}(id=${recorder.id})}" class="btn-detail">Szczegóły</a>
              <a th:href="@{/recorders/{id}/edit(id=${recorder.id})}" class="btn-edit">Edytuj</a>
              <form th:action="@{/recorders/{id}/delete(id=${recorder.id})}" method="post" style="display:inline" onsubmit="return confirm('Usunąć ten rejestrator?')">
                <button type="submit" class="btn-del">Usuń</button>
              </form>
            </div>
          </td>
        </tr>
      </tbody>
    </table>
    <div th:unless="${#lists.isEmpty(recorders)}" class="footer-bar">
      Łącznie: <span class="count" th:text="${#lists.size(recorders)}">0</span> rejestratorów
    </div>
  </div>
</div>
</body>
</html>
